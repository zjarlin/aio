{
  "schemaVersion": "system-capsule/v1",
  "id": "platform.capability-broker",
  "kind": "system",
  "displayName": "Capability Broker",
  "intent": "Expose audited file, process, browser, clipboard and notification capability providers through a single trusted broker.",
  "mutable": false,
  "replaceable": false,
  "managedBy": "platform",
  "platforms": {
    "supported": ["macos", "windows", "linux", "web", "remote"]
  },
  "capabilities": [
    {
      "id": "browser.openDirectory",
      "scope": "filesystem-directory",
      "reason": "Open a user-approved local directory in the system file manager."
    },
    {
      "id": "fs.read",
      "scope": "absolute-path",
      "reason": "Read user-approved text files through the broker."
    },
    {
      "id": "fs.write",
      "scope": "absolute-path",
      "reason": "Write user-approved text files through the broker."
    },
    {
      "id": "process.exec",
      "scope": "allowlisted-command",
      "reason": "Run allowlisted local commands through the broker with output auditing."
    },
    {
      "id": "browser.openUrl",
      "scope": "http-url",
      "reason": "Open HTTP(S) URLs in the user's browser through the broker."
    },
    {
      "id": "clipboard.read",
      "scope": "system-clipboard",
      "reason": "Read the current clipboard contents through the broker."
    },
    {
      "id": "clipboard.write",
      "scope": "system-clipboard",
      "reason": "Write clipboard contents through the broker."
    },
    {
      "id": "notification.send",
      "scope": "desktop-notification",
      "reason": "Send local desktop notifications through the broker."
    }
  ],
  "trustLevel": "platform",
  "contributes": {
    "commands": [
      {
        "id": "capability_invoke",
        "title": "Invoke Capability",
        "category": "capability-broker",
        "capabilities": [
          "browser.openDirectory",
          "fs.read",
          "fs.write",
          "process.exec",
          "browser.openUrl",
          "clipboard.read",
          "clipboard.write",
          "notification.send"
        ]
      },
      {
        "id": "capability_fs_read",
        "title": "Read Text File",
        "category": "capability-broker",
        "capabilities": ["fs.read"]
      },
      {
        "id": "capability_fs_write",
        "title": "Write Text File",
        "category": "capability-broker",
        "capabilities": ["fs.write"]
      },
      {
        "id": "capability_process_exec",
        "title": "Execute Allowlisted Process",
        "category": "capability-broker",
        "capabilities": ["process.exec"]
      },
      {
        "id": "capability_browser_open_url",
        "title": "Open Browser URL",
        "category": "capability-broker",
        "capabilities": ["browser.openUrl"]
      },
      {
        "id": "capability_clipboard_read",
        "title": "Read Clipboard",
        "category": "capability-broker",
        "capabilities": ["clipboard.read"]
      },
      {
        "id": "capability_clipboard_write",
        "title": "Write Clipboard",
        "category": "capability-broker",
        "capabilities": ["clipboard.write"]
      },
      {
        "id": "capability_notification_send",
        "title": "Send Notification",
        "category": "capability-broker",
        "capabilities": ["notification.send"]
      }
    ],
    "capabilityProviders": [
      {
        "id": "platform.capability-broker.directory",
        "title": "Built-in Directory Opener Provider",
        "capability": "browser.openDirectory",
        "kind": "native",
        "platforms": ["macos", "windows", "linux"],
        "trustLevel": "platform",
        "entry": "rust:capability_broker::open_directory",
        "fallback": "web-fallback.readonly",
        "when": "capability('browser.openDirectory')"
      },
      {
        "id": "platform.capability-broker.fs",
        "title": "Built-in File System Provider",
        "capability": "fs.read",
        "kind": "native",
        "platforms": ["macos", "windows", "linux"],
        "trustLevel": "platform",
        "entry": "rust:capability_broker::read_text_file",
        "fallback": "web-fallback.readonly",
        "when": "capability('fs.read')"
      },
      {
        "id": "platform.capability-broker.fs-write",
        "title": "Built-in File Write Provider",
        "capability": "fs.write",
        "kind": "native",
        "platforms": ["macos", "windows", "linux"],
        "trustLevel": "platform",
        "entry": "rust:capability_broker::write_text_file",
        "fallback": "web-fallback.readonly",
        "when": "capability('fs.write')"
      },
      {
        "id": "platform.capability-broker.process",
        "title": "Built-in Process Provider",
        "capability": "process.exec",
        "kind": "native",
        "platforms": ["macos", "windows", "linux"],
        "trustLevel": "platform",
        "entry": "rust:capability_broker::run_process",
        "fallback": "unsupported",
        "when": "capability('process.exec')"
      },
      {
        "id": "platform.capability-broker.browser",
        "title": "Built-in Browser URL Provider",
        "capability": "browser.openUrl",
        "kind": "native",
        "platforms": ["macos", "windows", "linux"],
        "trustLevel": "platform",
        "entry": "rust:capability_broker::open_url",
        "fallback": "web:window.open",
        "when": "capability('browser.openUrl')"
      },
      {
        "id": "platform.capability-broker.clipboard",
        "title": "Built-in Clipboard Provider",
        "capability": "clipboard.write",
        "kind": "native",
        "platforms": ["macos", "windows", "linux"],
        "trustLevel": "platform",
        "entry": "rust:capability_broker::write_clipboard",
        "fallback": "web:navigator.clipboard",
        "when": "capability('clipboard.write')"
      },
      {
        "id": "platform.capability-broker.clipboard-read",
        "title": "Built-in Clipboard Read Provider",
        "capability": "clipboard.read",
        "kind": "native",
        "platforms": ["macos", "windows", "linux"],
        "trustLevel": "platform",
        "entry": "rust:capability_broker::read_clipboard",
        "fallback": "web:navigator.clipboard",
        "when": "capability('clipboard.read')"
      },
      {
        "id": "platform.capability-broker.notification",
        "title": "Built-in Notification Provider",
        "capability": "notification.send",
        "kind": "native",
        "platforms": ["macos", "windows", "linux"],
        "trustLevel": "platform",
        "entry": "rust:capability_broker::send_notification",
        "fallback": "web:Notification",
        "when": "capability('notification.send')"
      },
      {
        "id": "platform.capability-broker.web-clipboard",
        "title": "Web Clipboard Provider",
        "capability": "clipboard.write",
        "kind": "web",
        "platforms": ["web"],
        "trustLevel": "platform",
        "entry": "web:navigator.clipboard.writeText",
        "fallback": "manual-copy",
        "when": "platform == 'web' && capability('clipboard.write')"
      },
      {
        "id": "platform.capability-broker.web-clipboard-read",
        "title": "Web Clipboard Read Provider",
        "capability": "clipboard.read",
        "kind": "web",
        "platforms": ["web"],
        "trustLevel": "platform",
        "entry": "web:navigator.clipboard.readText",
        "fallback": "manual-paste",
        "when": "platform == 'web' && capability('clipboard.read')"
      },
      {
        "id": "platform.capability-broker.web-notification",
        "title": "Web Notification Provider",
        "capability": "notification.send",
        "kind": "web",
        "platforms": ["web"],
        "trustLevel": "platform",
        "entry": "web:Notification",
        "fallback": "in-app-toast",
        "when": "platform == 'web' && capability('notification.send')"
      }
    ]
  },
  "ai": {
    "editableByAI": false,
    "role": "runtime",
    "primaryOutput": "capability-state",
    "repairStrategy": "diagnostics-first"
  }
}

# 端口号
VITE_PORT=5777

VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=/api

# 浏览器开发时使用本机命令桥，桌面端仍优先走 Tauri invoke
VITE_AIO_COMMAND_BRIDGE_URL=http://127.0.0.1:18777/__aio/command

# 是否开启 Nitro Mock服务，桌面本地业务通过 Tauri command，不启动 mock 后端
VITE_NITRO_MOCK=false

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

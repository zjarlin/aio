{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AIO",
  "version": "0.1.0",
  "identifier": "site.addzero.aio",
  "build": {
    "frontendDist": "../apps/web-ele/dist",
    "devUrl": "http://localhost:5777",
    "beforeDevCommand": "pnpm dev:ele",
    "beforeBuildCommand": "pnpm build:ele"
  },
  "app": {
    "windows": [
      {
        "title": "AIO",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

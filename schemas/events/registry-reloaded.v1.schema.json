{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://addzero.site/schemas/aio/events/registry-reloaded.v1.schema.json",
  "title": "AIO Plugin Registry Reloaded Event v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "plugins",
    "systemCapsules",
    "commands",
    "tools",
    "settings",
    "resources",
    "routes",
    "views"
  ],
  "properties": {
    "plugins": {
      "type": "integer",
      "minimum": 0
    },
    "systemCapsules": {
      "type": "integer",
      "minimum": 0
    },
    "commands": {
      "type": "integer",
      "minimum": 0
    },
    "tools": {
      "type": "integer",
      "minimum": 0
    },
    "settings": {
      "type": "integer",
      "minimum": 0
    },
    "resources": {
      "type": "integer",
      "minimum": 0
    },
    "routes": {
      "type": "integer",
      "minimum": 0
    },
    "views": {
      "type": "integer",
      "minimum": 0
    }
  }
}
